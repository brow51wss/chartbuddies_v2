# Development Environment Variables
# Copy this file to .env.local and fill in your DEVELOPMENT Supabase credentials
# This file is gitignored and should NOT be committed

# Development Supabase Configuration
# Create a separate Supabase project for development at: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key-here

# Environment identifier (optional, for debugging)
NEXT_PUBLIC_ENV=development

# Invite emails – we use Resend (required for "Send invite" to email the link)
# Get an API key at https://resend.com
RESEND_API_KEY=re_xxxxx
# From address (optional; default is onboarding@resend.dev for testing)
# RESEND_FROM_EMAIL=invites@yourdomain.com

# App URL for invite links in emails (optional – defaults to request host)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Production credentials should be set in Vercel Dashboard, not here
